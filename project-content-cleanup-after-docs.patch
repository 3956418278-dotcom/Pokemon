-    "        axis=1,\n",
-    "    )\n",
-    "    battles_df[\"opponent\"] = battles_df.apply(\n",
-    "        lambda r: r[\"team_1\"] if r[\"team_0\"] == TEAM_NAME else r[\"team_0\"] if r[\"team_1\"] == TEAM_NAME else \"\",\n",
