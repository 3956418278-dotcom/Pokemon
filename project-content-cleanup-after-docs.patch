-KAGGLE_INPUT = Path("/kaggle/input")
-KAGGLE_WORKING = Path("/kaggle/working")
-SCRIPT_DIR = Path(__file__).resolve().parent
-FEATURE_DIM = 48
-DEFAULT_SEED = 20260710
-
-
-RULE_WEIGHTS = {
-    "attack": 2.0,
-    "damage": 1.4,
-    "draw": 1.0,
-    "energy": 1.0,
-    "evolve": 0.8,
-    "retreat": -0.1,
-    "end": -0.3,
-    "random": 0.02,
-}
