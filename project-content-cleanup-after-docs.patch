-
-def option_text(option: Any) -> str:
-    if option is None:
-        return ""
-    values = []
-    for name in ("type", "number", "area", "index", "playerIndex", "attackId", "cardId", "inPlayArea"):
-        value = option_value(option, name)
-        if value is not None:
-            values.append(f"{name}:{value}")
