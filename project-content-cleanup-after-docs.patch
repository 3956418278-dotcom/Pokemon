-    if isinstance(obj, dict):
-        return {key: _normalize_value(value) for key, value in obj.items()}
-    if hasattr(obj, "to_dict"):
-        return {key: _normalize_value(value) for key, value in obj.to_dict().items()}
-    raw = getattr(obj, "__dict__", {})
